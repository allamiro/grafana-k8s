# Generated self-signed certificates -- never commit private keys.
certs/out/
grafana-dev-mimir/certs-out/
*.key
*.crt
*.csr
*.srl

# Saved container images (air-gap bundles). Hundreds of MB each -- GitHub
# rejects files >100MB. Rebuild them with the image-save script instead.
images/*.tar.gz
images/*.tar

# Downloaded packages (air-gap installs). Binaries -- refetch with
# ./packages/fetch-packages.sh; only the script + manifest are tracked.
packages/tarball/
packages/rpm/
packages/windows/
